# Spotify OAuth 授權用設定 (請自行填入真實憑證，並將檔名改為 `.env.dev`)
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here

# FastAPI 認證回呼的位置，因為我們前後端分離，請確保與 Spotify Developer Dashboard 一致
SPOTIPY_REDIRECT_URI=http://localhost:8000/callback

# 用於告知 FastAPI 允許哪個網域的前端存取 API (CORS)
BACKEND_CORS_ORIGINS=http://localhost:5173

# Auth Service
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# Spotify OAuth Redirect URI 需對應 Auth Service (Spotify Developer Dashboard 白名單也要加)
# SPOTIPY_REDIRECT_URI=http://127.0.0.1:8001/auth/spotify/callback

# PostgreSQL 資料庫設定
POSTGRES_DB=spotify_tidy
POSTGRES_USER=spotify_user
POSTGRES_PASSWORD=your_postgres_password_here
